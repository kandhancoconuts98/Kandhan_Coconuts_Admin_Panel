# Supabase (server-side)
# In Supabase Dashboard → Project Settings → API
#
# NOTE: Use the Service Role key ONLY on the server (never in NEXT_PUBLIC_).
# The app will use a server API route to push/pull farm data.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-only (Vercel env var)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Single-tenant farm ID (server-only). Pick any stable string.
COCONEST_FARM_ID=default
